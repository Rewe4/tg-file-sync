":2307,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2312,"length":38,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2350,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2355,"length":38,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2393,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2398,"length":123,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2521,"length":40,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2561,"length":14,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2575,"length":16,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2591,"length":13,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2604,"length":15,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2619,"length":12,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2631,"length":25,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2656,"length":25,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2681,"length":15,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2696,"length":2,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2698,"length":87,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":2785,"length":797,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294965488,"raisedBackground":4294965488,"additiveBackground":566857541,"textPrimary":4281737738,"textSecondary":4285421370,"invertedBackground":4287585049,"overlayBackground":3426099722},"darkThemeColorPalette":{"baseBackground":4280029442,"raisedBackground":4281737738,"additiveBackground":734629701,"textPrimary":4294635488,"textSecondary":4292724652,"invertedBackground":4293113724,"overlayBackground":3426099722},"colorSampledDescriptionBodyText":{"content":"Learn how to flip a car AKA buy a used car, fix it up, and sell it for a profit. In this video I teach you my tips and tricks on how to successfully flip a car including how to find a good used car, how to check the car for problems, and then how to fix up the car. Super cleaning the interior, super cleaning the engine bay, doing a paint correction, and restoring your cars headlights are just some things you will learn in this video! Learn to replace the hybrid battery in a Toyota Highlander. \n\nSearch Used Cars on AutoTempest:  http://www.autotempest.com/s/CarsFS\n\n4k Dash Cam: (use code \"3AS5KT7U\" for discount) https://amzlink.to/az0DT4tGgzCkH\nN4 Pro S:  (use code \"WPO6DKPY \" for discount) https://amzlink.to/az0E0u3Rib2B6\nBestBuy Exclusive N4 Pro: https://bit.ly/448uVB4\n\nWhere to get a Hybrid Battery: https://electronautomotive.com/\nToyota Highlander Hybrid Replacement Checklist: https://bit.ly/HighlanderHybridChecklist\n\nDiagnose Car\n12v Battery Tester: https://amzlink.to/az0Aw85gKl4DB\nOBD2 Car Scanner: https://bit.ly/4q3eajf\n\nTools:\nExtendable Ratchets: https://bit.ly/ExtendableRatchetSet\nPocket Pry Bars: https://bit.ly/MiniPryBar\nTorque Wrench: https://amzlink.to/az0JmVTbPrU62\nEye Protection: https://amzlink.to/az0rZy3UAf2RT\n\nInterior Clean\nDetailing Brushes (including vent brush): https://amzlink.to/az0gmAOjOIvhh\nInterior Protectant Spray: https://amzlink.to/az0jErp8lllke\nExtractor Vacuum: https://amzlink.to/az0BBxSFPyHI1\n\nExterior Paint Correction\nSmall Wireless DA Polisher: https://amzlink.to/az0NXy08PNNDW\nPolish+Wax: https://amzlink.to/az0QZhoGnluND\n\nEngine Bay Detail\nBrushes: https://amzlink.to/az0gmAOjOIvhh\nWater-based Dressing: https://amzlink.to/az0jErp8lllke\nStrong Air Blower: (use code \"GQTE5Q62\" for discount) https://amzlink.to/az0xv2hU2z18X\n\nHeadlight Restore: https://amzlink.to/az038bMrX0gVZ\n\n\n0:00 Intro\n3:06 New car reveal\n4:34 How to find a car to flip\n7:21 Tools and products needed\n7:52 How to test 12v battery\n8:25 How to scan the car computer for trouble codes\n9:44 How to remove a hybrid battery\n20:05 How to install an upgraded hybrid battery\n26:20 How to replace cabin air filter\n27:19 How to Super Clean your car's interior\n33:42 How to Super Clean your car's engine bay\n36:16 How to Super Clean your car's paint\n39:20 How to polish your car's paint\n41:26 How to restore your car's headlights\n44:08 How to install a Vantrue dash camera\n46:29 How to list and sell your car\n\n→ As an Amazon Associate I earn from qualifying purchases.\n→ Become a ChrisFix Subscriber: http://www.youtube.com/subscription_c...\n→ Instagram:   / chrisfixit  \n→ Facebook:   / chrisfix8  \n→ Website: http://www.ChrisFixed.com\n→ My Channel Home Page:    / chrisfix  \n\n*If the video was helpful, remember to give it a \"thumbs up\" and consider subscribing.*\n\nDisclaimer:\nDue to factors beyond the control of ChrisFix, I cannot guarantee against improper use or unauthorized modifications of this information. ChrisFix assumes no liability for property damage or injury incurred as a result of any of the information contained in this video. Use this information at your own risk. ChrisFix recommends safe practices when working on vehicles and or with tools seen or implied in this video. Due to factors beyond the control of ChrisFix, no information contained in this video shall create any expressed or implied warranty or guarantee of any particular result. Any injury, damage, or loss that may result from improper use of these tools, equipment, or from the information contained in this video is the sole responsibility of the user and not ChrisFix.","commandRuns":[{"startIndex":534,"length":35,"onTap":{"innertubeCommand":{"cl