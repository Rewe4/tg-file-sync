6099722},"darkThemeColorPalette":{"baseBackground":4280029442,"raisedBackground":4281737738,"additiveBackground":734629701,"textPrimary":4294635488,"textSecondary":4292724652,"invertedBackground":4293113724,"overlayBackground":3426099722},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"Dec 11"},"label":{"simpleText":"2025"},"accessibilityText":"Dec 11, 2025","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294965488,"raisedBackground":4294965488,"additiveBackground":566857541,"textPrimary":4281737738,"textSecondary":4285421370,"invertedBackground":4287585049,"overlayBackground":3426099722},"darkThemeColorPalette":{"baseBackground":4280029442,"raisedBackground":4281737738,"additiveBackground":734629701,"textPrimary":4294635488,"textSecondary":4292724652,"invertedBackground":4293113724,"overlayBackground":3426099722},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CB4Q040EGAciEwj8jbTLyJOUAxWuvisGHcDvBNDKAQQjpHMl","commandMetadata":{"webCommandMetadata":{"url":"/@chrisfix","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCes1EvRjcKU4sY_UEavndBw","canonicalBaseUrl":"/@chrisfix"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_lsMlPXxQcSMI_EveG6eb7sd1T9vFkEQrXKruSjabO_ANY=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Learn how to flip a car AKA buy a used car, fix it up, and sell it for a profit. In this video I teach you my tips and tricks on how to successfully flip a car including how to find a good used car, how to check the car for problems, and then how to fix up the car. Super cleaning the interior, super cleaning the engine bay, doing a paint correction, and restoring your cars headlights are just some things you will learn in this video! Learn to replace the hybrid battery in a Toyota Highlander. \n\nSearch Used Cars on AutoTempest:  http://www.autotempest.com/s/CarsFS\n\n4k Dash Cam: (use code \"3AS5KT7U\" for discount) https://amzlink.to/az0DT4tGgzCkH\nN4 Pro S:  (use code \"WPO6DKPY \" for discount) https://amzlink.to/az0E0u3Rib2B6\nBestBuy Exclusive N4 Pro: https://bit.ly/448uVB4\n\nWhere to get a Hybrid Battery: https://electronautomotive.com/\nToyota Highlander Hybrid Replacement Checklist: https://bit.ly/HighlanderHybridChecklist\n\nDiagnose Car\n12v Battery Tester: https://amzlink.to/az0Aw85gKl4DB\nOBD2 Car Scanner: https://bit.ly/4q3eajf\n\nTools:\nExtendable Ratchets: https://bit.ly/ExtendableRatchetSet\nPocket Pry Bars: https://bit.ly/MiniPryBar\nTorque Wrench: https://amzlink.to/az0JmVTbPrU62\nEye Protection: https://amzlink.to/az0rZy3UAf2RT\n\nInterior Clean\nDetailing Brushes (including vent brush): https://amzlink.to/az0gmAOjOIvhh\nInterior Protectant Spray: https://amzlink.to/az0jErp8lllke\nExtractor Vacuum: https://amzlink.to/az0BBxSFPyHI1\n\nExterior Paint Correction\nSmall Wireless DA Polisher: https://amzlink.to/az0NXy08PNNDW\nPolish+Wax: https://amzlink.to/az0QZhoGnluND\n\nEngine Bay Detail\nBrushes: https://amzlink.to/az0gmAOjOIvhh\nWater-based Dressing: https://amzlink.to/az0jErp8lllke\nStrong Air Blower: (use code \"GQTE5Q62\" for discount) https://amzlink.to/az0xv2hU2z18X\n\nHeadlight Restore: https://amzlink.to/az038bMrX0gVZ\n\n\n0:00 Intro\n3:06 New car reveal\n4:34 How to find a car to flip\n7:21 Tools and products needed\n7:52 How to test 12v battery\n8:25 How to scan the car computer for trouble codes\n9:44 How to remove a hybrid battery\n20:05 How to install an upgraded hybrid battery\n26:20 How to replace cabin air filter\n27:19 How to Super Clean your car's interior\n33:42 How to